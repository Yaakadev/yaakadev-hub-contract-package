{
  "name": "@yaakadev/hub-contract",
  "version": "0.3.0",
  "description": "Shared service-to-service contract (auth, schemas, guards) between the Yaakadev hub and its products.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yaakadev/yaakadev-hub-contract-package.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=16"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "default": "./dist/nestjs/index.js"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "default": "./dist/express/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "nestjs": ["dist/nestjs/index.d.ts"],
      "express": ["dist/express/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9",
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^18.19.0",
    "express": "^4.18.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typescript": "^5.4.5"
  }
}
